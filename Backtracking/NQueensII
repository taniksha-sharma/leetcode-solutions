/*
Problem: N-Queens II (LeetCode 52)

Approach:
- Use Backtracking to place queens row by row.
- At each row, try all columns and check if placing a queen is safe.
- Use 3 arrays to track:
  - columns
  - left diagonals (row + col)
  - right diagonals (row - col + n - 1)
- If all queens are placed → increment count.

Pattern:
- Backtracking + Constraint Checking

Time Complexity:
- O(N!) (worst case)

Space Complexity:
- O(N)
*/

class Solution {
    int count = 0;

    public int totalNQueens(int n) {
        boolean[] col = new boolean[n];
        boolean[] diag1 = new boolean[2 * n - 1];
        boolean[] diag2 = new boolean[2 * n - 1];

        solve(0, n, col, diag1, diag2);
        return count;
    }

    private void solve(int row, int n, boolean[] col, boolean[] diag1, boolean[] diag2) {
        if (row == n) {
            count++;
            return;
        }

        for (int c = 0; c < n; c++) {
            if (col[c] || diag1[row + c] || diag2[row - c + n - 1]) continue;

            col[c] = true;
            diag1[row + c] = true;
            diag2[row - c + n - 1] = true;

            solve(row + 1, n, col, diag1, diag2);

            col[c] = false;
            diag1[row + c] = false;
            diag2[row - c + n - 1] = false;
        }
    }
}